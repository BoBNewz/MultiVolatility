{
  "target_strict_score": 95,
  "review_max_age_days": 30,
  "review_batch_max_files": 80,
  "holistic_max_age_days": 30,
  "generate_scorecard": true,
  "badge_path": "scorecard.png",
  "exclude": [
    "CLI/build",
    "CLI/dist",
    "CLI/multivol.egg-info",
    "Web/node_modules",
    "outputs",
    "CLI/outputs",
    "multivol/outputs",
    "storage",
    "CLI/storage",
    "volatility3_cache",
    "CLI/volatility3_cache",
    "multivol/volatility3_cache",
    "volatility2_profiles",
    "CLI/volatility2_profiles",
    "volatility3_symbols",
    "CLI/volatility3_symbols",
    "multivol/volatility3_symbols",
    "volatility3_plugins",
    "CLI/volatility3_plugins",
    "multivol/volatility3_plugins"
  ],
  "ignore": [],
  "ignore_metadata": {},
  "zone_overrides": {},
  "review_dimensions": [],
  "large_files_threshold": 0,
  "props_threshold": 0,
  "issue_noise_budget": 10,
  "issue_noise_global_budget": 0,
  "execution_log_max_entries": 10000,
  "needs_rescan": false,
  "languages": {},
  "commit_tracking_enabled": true,
  "commit_pr": 0,
  "commit_default_branch": "",
  "commit_message_template": "desloppify: {status} {count} issue(s) \u2014 {summary}",
  "trust_plugins": false
}
