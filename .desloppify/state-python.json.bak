        ],
        "evidence": [
          "rename_scan returns {\"status\": \"updated\"}, delete_scan returns {\"status\": \"deleted\"} (scan.py lines 590, 615)",
          "update_scan_module_status returns {\"success\": True} (scan.py line 345)",
          "manage_symbols POST returns {\"message\": \"Symbol uploaded successfully\"}, DELETE returns {\"message\": \"Deleted successfully\"} (files.py)",
