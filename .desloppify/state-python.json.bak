    "review::.::holistic::low_level_elegance::pervasive_bare_except": {
      "id": "review::.::holistic::low_level_elegance::pervasive_bare_except",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "12 bare `except:` blocks across seed files silently swallow all exceptions including SystemExit and KeyboardInterrupt",
      "detail": {
        "holistic": true,
        "dimension": "low_level_elegance",
        "related_files": [
          "CLI/multivol/api_server/utils.py",
          "CLI/multivol/api_server/routes/scan.py",
          "CLI/multivol/api_server/routes/files.py",
          "CLI/multivol/multi_volatility3.py",
          "CLI/multivol/multi_volatility2.py"
        ],
        "evidence": [
          "utils.py:32 \u2014 bare except in resolve_host_path after importing config: swallows ImportError and any other exception with a silent fallback, making path translation failures invisible.",
          "utils.py:83,91 \u2014 two consecutive bare excepts in clean_and_parse_json try/fallback chain: a caller receives parsed_data=None with no indication of what went wrong.",
          "files.py:123 \u2014 bare except around the entire DB case-map loading block: if the DB is corrupt or schema-mismatched, the caller proceeds with an empty case_map silently.",
          "multi_volatility3.py:157,197 and multi_volatility2.py:78,108 \u2014 bare excepts in resolve_path and container-cleanup code swallow docker SDK errors."
        ],
        "suggestion": "Replace bare except with the narrowest applicable exception type. For ImportError fallbacks: `except ImportError`. For JSON parse failures: `except (json.JSONDecodeError, ValueError)`. For docker container-not-found: `except docker.errors.NotFound`. For IO operations: `except OSError`. Where a fallback is intentional, add a logging.debug() call so the suppression is visible in debug mode.",
        "reasoning": "",
        "content_hash": "cf2696ed"
      },
      "status": "fixed",
      "note": "All bare except: replaced with typed exceptions across scan.py, memprocfs.py, docker.py, files.py, multivol.py, utils.py, multi_volatility2.py, multi_volatility3.py",
      "first_seen": "2026-03-11T08:28:11+00:00",
      "last_seen": "2026-03-11T16:16:19+00:00",
      "resolved_at": "2026-03-11T16:43:43+00:00",
      "reopen_count": 0,
      "lang": "python",
      "suppressed": false,
      "suppressed_at": null,
      "suppression_pattern": null,
      "resolution_attestation": {
