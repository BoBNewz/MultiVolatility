    "review::.::holistic::error_consistency::database_schema_migration_silent_failure": {
      "id": "review::.::holistic::error_consistency::database_schema_migration_silent_failure",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "database.py schema migration swallows ADD COLUMN failure silently, leaving schema state unknown to callers",
      "detail": {
        "holistic": true,
        "dimension": "error_consistency",
        "related_files": [
          "CLI/multivol/api_server/database.py"
        ],
        "evidence": [
          "database.py lines 99-101: `try: c.execute('ALTER TABLE scans ADD COLUMN name TEXT') except: pass` \u2014 if this fails (e.g., locked DB, permissions), init_db() returns successfully with no indication of the problem",
          "A following `conn.commit()` commits whatever partial state resulted, potentially leaving the application running against a schema that is missing a required column"
        ],
        "suggestion": "Remove the bare `except: pass` and let the exception propagate from init_db(), or catch only `sqlite3.OperationalError` with an explicit re-check and log. The silent swallow hides a startup-time failure that will cause hard-to-diagnose query errors later.",
        "reasoning": "",
        "content_hash": "a71f7ee7"
      },
      "status": "fixed",
      "note": "Migration catches exceptions with logging.error; critical failures re-raised via init_db caller",
