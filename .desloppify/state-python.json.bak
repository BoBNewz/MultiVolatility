    "review::.::holistic::cross_module_architecture::orphaned_strings_extension_shim": {
      "id": "review::.::holistic::cross_module_architecture::orphaned_strings_extension_shim",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "api_strings_extension.py references app and DB_PATH from old monolithic architecture \u2014 never imported, unrunnable, blurs migration boundary",
