    "review::.::holistic::design_coherence::argparse_namespace_as_api_data_carrier": {
      "id": "review::.::holistic::design_coherence::argparse_namespace_as_api_data_carrier",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "scan() uses argparse.Namespace as a data-transfer object, leaking CLI-layer abstractions into the API dispatch layer",
      "detail": {
        "holistic": true,
        "dimension": "design_coherence",
        "related_files": [
          "CLI/multivol/api_server/routes/scan.py",
          "CLI/multivol/multivol.py"
        ],
        "evidence": [
          "scan() builds args_dict from API request data, then calls argparse.Namespace(**args_dict) to produce args_obj, then passes it to runner() which was designed for CLI-parsed arguments.",
          "runner() uses getattr(arguments, 'fetch_symbol', False), getattr(arguments, 'debug', False), getattr(arguments, 'custom_symbol', None) with defaults because the API may not populate all CLI fields \u2014 these guards exist because the data carrier is wrong.",
          "argparse.Namespace has no type enforcement, no required-field guarantees, and no documentation of expected shape \u2014 it is an opaque dict with attribute access."
        ],
        "suggestion": "Define a ScanRequest dataclass (or TypedDict) that describes the fields runner() actually needs. Both the CLI main() and the API scan() should convert their respective input representations into this object before calling runner(). This removes the argparse.Namespace from the API path and makes runner()'s contract explicit.",
        "reasoning": "",
        "content_hash": "49549161"
      },
      "status": "fixed",
